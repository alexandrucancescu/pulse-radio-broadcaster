# ── Server ──────────────────────────────────────────
HOST=0.0.0.0
PORT=3000

# ── RTP Receiver ────────────────────────────────────
RTP_HOST=0.0.0.0
RTP_PORT=3100
RTP_SAMPLE_RATE=44100
RTP_FORMAT=s16be
# Comma-separated IPs or CIDR ranges allowed to send RTP data
RTP_ALLOWED_IPS=192.168.0.0/16
# Seconds of silence before stopping encoders and disconnecting listeners
RTP_NO_DATA_DISCONNECT_DELAY=60

# ── Streams (JSON array) ───────────────────────────
# Each stream object:
#   format    - mp3, aac, aac_he, aac_he_v2, adts, opus
#   paths     - array of HTTP paths to serve the stream on
#   bitrate   - (optional) kbps, default 128
#   channels  - (optional) default 2
#   codec     - (optional) override ffmpeg codec
#   sampleRate - (optional) output sample rate
#   options   - (optional) extra ffmpeg args
#   contentType - (optional) override Content-Type header
#   burstSize - (optional) burst buffer size in bytes
#   headers   - (optional) extra HTTP headers
STREAMS='[{"format":"mp3","paths":["/stream","/stream.mp3"],"bitrate":192},{"format":"adts","paths":["/stream.aac"],"bitrate":256}]'

# ── Station metadata (Icy headers) ─────────────────
STATION_NAME=Radio Station
STATION_DESCRIPTION=N/A
STATION_GENRE=N/A
STATION_PUBLIC=true

# ── Global headers (JSON object, applied to all streams)
# GLOBAL_HEADERS='{"Access-Control-Allow-Origin":"*","Cache-Control":"no-store, no-cache, must-revalidate"}'

# ── Logging ─────────────────────────────────────────
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Statistics endpoint (/stats) ───────────────────
# Both must be set to enable the endpoint
# STATS_USERNAME=admin
# STATS_PASSWORD=changeme123
