{
  "name": "pulse-radio-broadcaster",
  "version": "0.0.4",
  "description": "Online radio broadcasting server that converts RTP PCM data into various formats including AAC, MP3, Opus, and more. It features customisable streaming points, burst buffering for seamless listening, and comprehensive statistics, making it a highly configurable solution.",
  "exports": "./dist/run.js",
  "engines": {
    "node": ">=21"
  },
  "bin": {
    "pulse-radio": "./dist/run.js"
  },
  "scripts": {
    "build": "tsc && pnpm --dir ui build",
    "build:server": "tsc",
    "build:ui": "pnpm --dir ui build",
    "start": "node dist/run.js",
    "dev": "node --env-file=.env --watch --import=tsx/esm src/run.ts",
    "test": "vitest run"
  },
  "type": "module",
  "author": "Alexandru Cancescu",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.4.0",
    "@fastify/cookie": "^11.1.2",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "@t3-oss/env-core": "^0.13.11",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "fast-geoip": "^1.1.88",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "fastify-sse-v2": "^4.2.2",
    "fluent-ffmpeg": "github:alexandrucancescu/node-fluent-ffmpeg",
    "ip": "^2.0.1",
    "jose": "^6.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^10.3.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "useragent": "^2.3.0",
    "zod": "~3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/ip": "^1.1.3",
    "@types/node": "^20.11.19",
    "@types/useragent": "^2.3.4",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "broadcast",
    "radio streaming",
    "online radio",
    "icecast",
    "shoutcast",
    "rtp",
    "audio",
    "http streaming",
    "online streaming"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "minimumReleaseAge": 20160
  }
}